# Copy this file to .env in the project root and fill in your values.
# The .env file must be in the same folder as docker-compose.yml.

# Database (Docker uses service name "db"; local dev uses localhost)
DATABASE_URL=postgresql://postgres:postgres@db:5432/tradeswap

# AWS S3 — required for item photo uploads
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_BUCKET_REGION=your-region        # e.g. ap-southeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Seeded admin account (created automatically on first run)
ADMIN_USER_NAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
