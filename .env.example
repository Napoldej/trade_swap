# Copy this file to backend/.env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tradeswap

# JWT
JWT_SECRET=your-jwt-secret

# AWS S3 — required for item photo uploads
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_BUCKET_REGION=your-region        # e.g. ap-southeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Admin seed — used once by `npm run seed` to create the first admin account
ADMIN_USER_NAME=admin12345
ADMIN_EMAIL=admin1234@example.com
ADMIN_PASSWORD=admin12345
